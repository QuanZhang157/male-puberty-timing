lungcancer <- read.csv('data_participant.csv')
colnames(lungcancer) <- c('ID','Sex','Last.contact.with.UKB','Lost.to.follow.up','Smoking','Amount.of.smoking','Diagnosis.date','Diagnosis.age','Histology','Death.date','Deprivation.index','Townsend.deprivation','Household.number','Household.income','Length.of.working.week','Heavy.job','Night.job','Ethnic','Moderate.activity','Strenuous.sport','Mobile.phone.use','Sleep','Getting.up','Nap','Dried.fruit','Fresh.fruit','Salt.add','Coffee','Alcohol','Alcohol.frequency','Outdoors.summer','Outdoors.winter','Outdoors.winter2','Breastfed','Able.to.confide','Irritability','Miserableness','Sensitivity','Nervous','Happiness','First.facial.hair','Voice.broke','Balding','Menarche','Menopause','Menopause.age','Assessment.centre')
lungcancer$Region <- ifelse(lungcancer$`Assessment.centre` %in% c("Edinburgh", "Glasgow"), "Scotland",
ifelse(lungcancer$`Assessment.centre` %in% c("Cardiff", "Swansea", "Wrexham"), "Wales", "England"))
library(dplyr)
lungcancer <- lungcancer %>%
mutate(Histology.cancer = case_when(
# Squamous
Histology %in% c(8052, 8070, 8071, 8072, 8073, 8074, 8083, 8084) ~ "Squamous",
# Adenocarcinomas
Histology %in% c(8140, 8250, 8251, 8252, 8253, 8254, 8255, 8260,
+                          8323, 8480, 8481, 8490, 8550, 8570, 8571, 8572, 8574) ~ "Adenocarcinomas",
# жіЁж„Ҹпјҡд»ҺAdenocarcinomasдёӯз§»йҷӨдәҶ8310пјҢеӣ дёәе®ғеҗҢж—¶еҮәзҺ°еңЁLarge cellз»„дёӯ
# Large cell
Histology %in% c(8012, 8013, 8032, 8310) ~ "Large cell",
# Neuroendocrine
Histology %in% c(8041, 8042, 8043, 8044, 8045, 8240, 8246, 8249) ~ "Neuroendocrine",
# Unspecified
Histology %in% c(8020, 8021, 8022, 8030, 8031, 8033, 8034, 8035, 8046, 8560) ~ "Unspecified",
# Salivary gland type
Histology %in% c(8200, 8430, 8980) ~ "Salivary gland type",
# дёҚеңЁд»ҘдёҠд»»дҪ•дёҖз»„зҡ„еҖји®ҫдёәNA
TRUE ~ NA_character_
))
