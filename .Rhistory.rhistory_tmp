names(lungcancer)[names(lungcancer) == "OS_years_rounded"] <- "OS"
cols_to_check1 <- c("First.facial.hair", "Voice.broke")
# еҲ йҷӨжҢҮе®ҡдёүеҲ—дёӯд»»ж„ҸдёҖеҲ—дёәз©әеӯ—з¬ҰдёІжҲ–NAзҡ„иЎҢ
lungcancer_man <- lungcancer %>%
filter(
if_all(all_of(cols_to_check1), ~ !is.na(.) & trimws(as.character(.)) != "")
)
lungcancer_man <- lungcancer_man[!(lungcancer_man$First.facial.hair %in% c("Do not know", "Prefer not to answer") | lungcancer_man$Voice.broke %in% c("Do not know", "Prefer not to answer")), ]
lungcancer_man$First.facial.hair2 <- paste0("facial hair",lungcancer_man$First.facial.hair)
lungcancer_man$Voice.broke2 <- paste0("voice broke",lungcancer_man$Voice.broke)
lungcancer_man$male.characteristics <- paste0(lungcancer_man$First.facial.hair2,lungcancer_man$Voice.broke2)
lungcancer_man <- lungcancer_man %>%
mutate(
male.characteristics2 = ifelse(
male.characteristics=="facial hairAbout average agevoice brokeOlder than average",
"hair average+voice older",
ifelse(
male.characteristics=="facial hairAbout average agevoice brokeYounger than average",
"hair average+voice younger",
ifelse(male.characteristics=="facial hairOlder than averagevoice brokeAbout average age","hair older+voice average",ifelse(male.characteristics=="facial hairOlder than averagevoice brokeOlder than average","hair older+voice older",ifelse(male.characteristics=="facial hairOlder than averagevoice brokeYounger than average","hair older+voice younger",ifelse(male.characteristics=="facial hairYounger than averagevoice brokeAbout average age","hair younger+voice average",ifelse(male.characteristics=="facial hairYounger than averagevoice brokeOlder than average","hair younger+voice older",ifelse(male.characteristics=="facial hairYounger than averagevoice brokeYounger than average","hair younger+voice younger","hair average+voice average"))))))
)))
###lungcancer_man$Townsend.deprivation <- ifelse(lungcancer_man$Townsend.deprivation<=-3.49,"Quintile1",ifelse(lungcancer_man$Townsend.deprivation>-3.49&lungcancer_man$Townsend.deprivation<=-0.49,"Quintile2",ifelse(lungcancer_man$Townsend.deprivation>-0.49&lungcancer_man$Townsend.deprivation<=3.49,"Quintile3",ifelse(lungcancer_man$Townsend.deprivation>3.49&lungcancer_man$Townsend.deprivation<=7.49,"Quintile4","Quintile5"))))
library(survival)      # CoxеӣһеҪ’еҲҶжһҗ
library(survminer)     # з”ҹеӯҳеҲҶжһҗеҸҜи§ҶеҢ–
library(tidyverse)     # ж•°жҚ®еӨ„зҗҶ
library(broom)         # жЁЎеһӢз»“жһңж•ҙзҗҶ
library(forestplot)
###lung_cancer
lung_cancer <- filter(lungcancer_man,lungcancer_man$cancer_type_group=="Lung Cancer")
###multi cox
lungcancer_man$Ethnic <- ifelse(lungcancer_man$Ethnic%in%c("White","British","Irish","Any other white background","White and Asian","White and Black African","White and Black Caribbean"),"White",ifelse(lungcancer_man$Ethnic%in%c("Any other Black background","African","Black or Black British","Caribbean"),"Black",ifelse(lungcancer_man$Ethnic%in%c("Any other Asian background","Bangladeshi","Chinese","Indian","Pakistani"),"Asian","Others")))
table(lungcancer_man$Ethnic)
lungcancer_man$Alcohol <- ifelse(lungcancer_man$Alcohol=="Current","Current",ifelse(lungcancer_man$Alcohol=="Never","Never",ifelse(lungcancer_man$Alcohol=="Previous","Previous","Others")))
table(lungcancer_man$Smoking)
table(lungcancer_man$Alcohol)
lungcancer_man$Breastfed <- ifelse(lungcancer_man$Breastfed=="Yes","Yes",ifelse(lungcancer_man$Breastfed=="No","No","Others"))
#lungcancer_man$Histology.cancer <- ifelse(lung_cancer$Histology.cancer=="Adenocarcinomas","Adenocarcinomas",ifelse(lung_cancer$Histology.cancer=="Squamous","Squamous","Others"))
cox_model <- coxph(Surv(OS, Status) ~ Diagnosis.age + Townsend.deprivation +
Household.income + Ethnic + Alcohol + Breastfed +
male.characteristics2,
data = lungcancer_man)
model_summary <- summary(cox_model)
summary(cox_model)
results <- data.frame(
Variable = rownames(model_summary$coefficients),
HR = model_summary$coefficients[, "exp(coef)"],
CI_lower = model_summary$conf.int[, "lower .95"],
CI_upper = model_summary$conf.int[, "upper .95"],
p_value = model_summary$coefficients[, "Pr(>|z|)"]
)
# 4. зӯӣйҖүжҳҫи‘—еҸҳйҮҸ (p < 0.05)
significant_results <- results %>%
filter(p_value < 0.05) %>%
arrange(p_value)  # жҢүpеҖјжҺ’еәҸ
View(significant_results)
table(lungcancer_man$Household.income)
significant_results <- significant_results[c(6,1,2,7,13,12,10,11),]
###еҮҶеӨҮж•°жҚ®
tabletext <- cbind(
c("Variable", as.character(significant_results$Variable)),
c("HR (95% CI)", sprintf("%.2f (%.2f-%.2f)",
significant_results$HR,
significant_results$CI_lower,
significant_results$CI_upper)),
c("P Value", sprintf("%.3f", significant_results$p_value))
)
# еҮҶеӨҮжЈ®жһ—еӣҫзҡ„дј°и®ЎеҖје’ҢзҪ®дҝЎеҢәй—ҙ
mean <- c(NA, significant_results$HR)
lower <- c(NA, significant_results$CI_lower)
upper <- c(NA, significant_results$CI_upper)
forestplot(labeltext = tabletext,
mean = mean,
clip=c(0,3),
lower = lower,
upper = upper,
lineheight = unit(1, "cm"),
colgap = unit(0.5, "cm"),
xlab = "Hazard Ratio",
xticks = c(0, 1, 2 ),
graph.pos = 2,  # жЈ®жһ—еӣҫеңЁз¬¬дәҢеҲ—
zero = 1,  # еҸӮиҖғзәҝеңЁHR=1еӨ„
boxsize = 0.15,
col = fpColors(box = "blue", line = "blue"),
txt_gp = fpTxtGp(cex = 0.9),
hrzl_lines = list("2" = gpar(lty = 2)),
title = "Multivariable Cox Regression Analysis\n(Significant Variables Only, P < 0.05)")
