lungcancer_man$Smoking <- ifelse(lungcancer_man$Smoking=="Ex-smoker","Previous",ifelse(lungcancer_man$Smoking=="Never smoked","Never",ifelse(lungcancer_man%in%c("Occasionally","Smokes on most or all days"),"Current","Others")))
table(lungcancer_man$Smoking)
