Cancer.type <- read.csv('cancer type')
colnames(Cancer.type) <- c("ID","cancer type")
###Cancer.type <- Cancer.type[grep("C34", Cancer.type$`cancer type`), ]
lungcancer <- inner_join(lungcancer, Cancer.type, by = "ID")
lungcancer <- lungcancer %>% filter(!is.na(Histology.cancer))
lungcancer <- lungcancer %>%
mutate(
# жҸҗеҸ–зј–з ҒеүҚзјҖ
icd_prefix = substr(`cancer type`, 1, 3),
# еҲӣе»әж–°еҲ—
cancer_type_group = case_when(
icd_prefix %in% c("C00", "C01", "C02", "C03", "C04", "C05", "C06",
"C07", "C08", "C09", "C10", "C11", "C12", "C13", "C14") ~ "Oral Cavity and Pharyngeal Cancer",
icd_prefix == "C15" ~ "Esophageal Cancer",
icd_prefix == "C16" ~ "Stomach Cancer",
icd_prefix %in% c("C17", "C18", "C19", "C20", "C21") ~ "Colorectal Cancer",
icd_prefix %in% c("C22", "C23", "C24") ~ "Liver and Biliary Tract Cancer",
icd_prefix == "C25" ~ "Pancreatic Cancer",
icd_prefix == "C34" ~ "Lung Cancer",
icd_prefix == "C32" ~ "Laryngeal Cancer",
icd_prefix == "C11" ~ "Nasopharyngeal Cancer",
icd_prefix %in% c("C43", "C44") ~ "Skin Cancer",
icd_prefix == "C50" ~ "Breast Cancer",
icd_prefix == "C53" ~ "Cervical Cancer",
icd_prefix == "C56" ~ "Ovarian Cancer",
icd_prefix == "C54" ~ "Endometrial Cancer",
icd_prefix == "C61" ~ "Prostate Cancer",
icd_prefix == "C64" ~ "Kidney Cancer",
icd_prefix == "C67" ~ "Bladder Cancer",
icd_prefix == "C73" ~ "Thyroid Cancer",
icd_prefix == "C71" ~ "Brain Cancer",
TRUE ~ "Other/Unspecified"
)
) %>%
select(-icd_prefix)  # з§»йҷӨдёҙж—¶еҲ—
table(lungcancer$cancer_type_group, useNA = "always")
lungcancer <- lungcancer %>%
mutate(Censoring.date = case_when(
Region %in% c("England", "Wales") ~ as.Date("2024-08-31"),
Region == "Scotland" ~ as.Date("2024-11-30"),
TRUE ~ as.Date(NA)  # е…¶д»–жғ…еҶөи®ҫдёәNA
))
basic.time <- read.csv('basic time')
names(basic.time)[names(basic.time) == "Participant.ID"] <- "ID"
colnames(basic.time)[2] <-"basic.time"
Testosterone <- read.csv('Testosterone')
names(Testosterone)[names(Testosterone) == "Participant.ID"] <- "ID"
colnames(Testosterone)[2] <-c("Testosterone")
colnames(Testosterone)[3] <-c("Estradiol")
library(dplyr)
# дҪҝз”Ёinner_joinеҸӘдҝқз•ҷе…ұжңүID
lungcancer <- inner_join(lungcancer, basic.time, by = "ID")
lungcancer <- inner_join(lungcancer, Testosterone, by = "ID")
lungcancer <- lungcancer %>%
mutate(
Testosterone.level = ifelse(
Testosterone<12,
"low level",
ifelse(
Testosterone>35.4,
"high level",
"normal level"
)))
lungcancer <- lungcancer %>%
mutate(
# зӣҙжҺҘиҪ¬жҚўдёәж—Ҙжңҹж јејҸпјҢз©әзҷҪдјҡиҮӘеҠЁиҪ¬дёәNA
Death.date = as.Date(Death.date),
Diagnosis.date = as.Date(Diagnosis.date),
Lost.to.follow.up = as.Date(Lost.to.follow.up),
Censoring.date = as.Date(Censoring.date),
basic.time = as.Date(basic.time)
)
lungcancer <- lungcancer %>%
mutate(
# и®Ўз®—OSпјҲжҖ»з”ҹеӯҳжңҹпјүе’ҢStatus
OS = ifelse(
!is.na(Death.date),  # Death.dateдёҚдёәз©әзҷҪ
as.numeric(Death.date - basic.time),  # жӯ»дәЎж—Ҙжңҹ - иҜҠж–ӯж—Ҙжңҹ
ifelse(
!is.na(Lost.to.follow.up),  # Lost.to.follow.upдёҚдёәз©әзҷҪ
as.numeric(Lost.to.follow.up - basic.time),  # еӨұи®ҝж—Ҙжңҹ - иҜҠж–ӯж—Ҙжңҹ
as.numeric(Censoring.date - basic.time)  # жҲӘжӯўж—Ҙжңҹ - иҜҠж–ӯж—Ҙжңҹ
)
),
# StatusеҲ—пјҡDeath.dateдёҚдёәз©әзҷҪеҲҷдёә1пјҢеҗҰеҲҷдёә0
Status = ifelse(!is.na(Death.date), 1, 0)
)
lungcancer <- lungcancer %>%
mutate(
# дҝқжҢҒеҺҹе§ӢOSпјҲеӨ©пјү
OS_days = OS,
# иҪ¬жҚўдёәжңҲ
OS_months = OS_days / 30.44,
# иҪ¬жҚўдёәе№ҙ
OS_years = OS_days / 365.25,
# еӣӣиҲҚдә”е…ҘеҲ°дёӨдҪҚе°Ҹж•°
OS_months_rounded = round(OS_months, 2),
OS_years_rounded = round(OS_years, 2)
)
lungcancer <- lungcancer %>%
select(-c(OS, OS_days,OS_months,OS_years,OS_months_rounded))
names(lungcancer)[names(lungcancer) == "OS_years_rounded"] <- "OS"
cols_to_check1 <- c("First.facial.hair", "Voice.broke")
# еҲ йҷӨжҢҮе®ҡдёүеҲ—дёӯд»»ж„ҸдёҖеҲ—дёәз©әеӯ—з¬ҰдёІжҲ–NAзҡ„иЎҢ
lungcancer_man <- lungcancer %>%
filter(
if_all(all_of(cols_to_check1), ~ !is.na(.) & trimws(as.character(.)) != "")
)
lungcancer_man <- lungcancer_man[!(lungcancer_man$First.facial.hair %in% c("Do not know", "Prefer not to answer") | lungcancer_man$Voice.broke %in% c("Do not know", "Prefer not to answer")), ]
lungcancer_man$First.facial.hair2 <- paste0("facial hair",lungcancer_man$First.facial.hair)
lungcancer_man$Voice.broke2 <- paste0("voice broke",lungcancer_man$Voice.broke)
lungcancer_man$male.characteristics <- paste0(lungcancer_man$First.facial.hair2,lungcancer_man$Voice.broke2)
lungcancer_man <- lungcancer_man %>%
mutate(
male.characteristics2 = ifelse(
male.characteristics=="facial hairAbout average agevoice brokeOlder than average",
"hair average+voice older",
ifelse(
male.characteristics=="facial hairAbout average agevoice brokeYounger than average",
"hair average+voice younger",
ifelse(male.characteristics=="facial hairOlder than averagevoice brokeAbout average age","hair older+voice average",ifelse(male.characteristics=="facial hairOlder than averagevoice brokeOlder than average","hair older+voice older",ifelse(male.characteristics=="facial hairOlder than averagevoice brokeYounger than average","hair older+voice younger",ifelse(male.characteristics=="facial hairYounger than averagevoice brokeAbout average age","hair younger+voice average",ifelse(male.characteristics=="facial hairYounger than averagevoice brokeOlder than average","hair younger+voice older",ifelse(male.characteristics=="facial hairYounger than averagevoice brokeYounger than average","hair younger+voice younger","hair average+voice average"))))))
)))
###lungcancer_man$Townsend.deprivation <- ifelse(lungcancer_man$Townsend.deprivation<=-3.49,"Quintile1",ifelse(lungcancer_man$Townsend.deprivation>-3.49&lungcancer_man$Townsend.deprivation<=-0.49,"Quintile2",ifelse(lungcancer_man$Townsend.deprivation>-0.49&lungcancer_man$Townsend.deprivation<=3.49,"Quintile3",ifelse(lungcancer_man$Townsend.deprivation>3.49&lungcancer_man$Townsend.deprivation<=7.49,"Quintile4","Quintile5"))))
library(survival)      # CoxеӣһеҪ’еҲҶжһҗ
library(survminer)     # з”ҹеӯҳеҲҶжһҗеҸҜи§ҶеҢ–
library(tidyverse)     # ж•°жҚ®еӨ„зҗҶ
library(broom)         # жЁЎеһӢз»“жһңж•ҙзҗҶ
library(forestplot)
View(lungcancer_man)
tableпјҲlungcancer_man$Smokingпјү
table(lungcancer_man$Smoking)
table(lungcancer_man$Alcohol)
###lung_cancer
lung_cancer <- filter(lungcancer_man,lungcancer_man$cancer_type_group=="Lung Cancer")
cox_facial <- coxph(Surv(OS, Status) ~ lung_cancer$First.facial.hair, data = lung_cancer)
summary(cox_facial)
cox_voice <- coxph(Surv(OS, Status) ~ lung_cancer$Voice.broke, data = lung_cancer)
summary(cox_voice)
fit1<- survfit(Surv(OS, Status) ~ First.facial.hair, data = lung_cancer)
ggsurvplot(
fit1,
pval = TRUE,
risk.table = TRUE,
palette = "jco",
censor.size=2.5,
xlab = "Years",
ylab="OS(probability)",
legend.labs = c("About average age","Older than average", "Younger than average"),
legend.title = " ",
title = "First facial hair",
surv.median.line = "hv",  # еҠ дёҠдёӯдҪҚз”ҹеӯҳзәҝ
legend = c(0.8, 0.9),# еӣҫдҫӢз§»еҲ°еҸідёҠи§’
)
fit2<- survfit(Surv(OS, Status) ~ Voice.broke, data = lung_cancer)
ggsurvplot(
fit2,
pval = TRUE,
risk.table = TRUE,
palette = "jco",
censor.size=2.5,
xlab = "Years",
ylab="OS(probability)",
legend.labs = c("About average age","Older than average", "Younger than average"),
legend.title = " ",
title = "Voice broke",
surv.median.line = "hv",  # еҠ дёҠдёӯдҪҚз”ҹеӯҳзәҝ
legend = c(0.8, 0.9),# еӣҫдҫӢз§»еҲ°еҸідёҠи§’
)
